# Shared .env.local for all Next.js apps (copy to apps/student, apps/admin, apps/super-admin)

#NEXT_PUBLIC_API_URL=https://api.yourplatform.com
#NEXT_PUBLIC_TRPC_URL=https://api.yourplatform.com/trpc
#NEXT_PUBLIC_PLATFORM_DOMAIN=yourplatform.com
#NEXT_PUBLIC_COOKIE_DOMAIN=.yourplatform.com

# For local dev:
 NEXT_PUBLIC_API_URL=http://localhost:3000
 NEXT_PUBLIC_TRPC_URL=http://localhost:3000/trpc
 NEXT_PUBLIC_PLATFORM_DOMAIN=localhost
 NEXT_PUBLIC_COOKIE_DOMAIN=localhost
